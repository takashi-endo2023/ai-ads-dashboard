{
  "name": "ai-ads-backend",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:debug": "ts-node -r tsconfig-paths/register --inspect src/main.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@vendia/serverless-express": "^4.12.6",
    "aws-lambda": "^1.0.7",
    "dotenv": "^16.4.7",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.5.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.21",
    "@types/papaparse": "^5.3.15",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
